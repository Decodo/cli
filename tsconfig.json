{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "outDir": "build",
    "rootDir": "."
  },
  "include": ["src/**/*", "tests/**/*", "vitest.config.ts"],
  "exclude": ["build/**"]
}
